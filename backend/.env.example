DATABASE_URL=postgresql://user:password@localhost:5432/db
BOT_TOKEN=
OPENROUTER_API_KEY=
PORT=3000
ADMIN_TELEGRAM_IDS=
NODE_ENV=development
JWT_SECRET=
ALLOWED_ORIGINS=https://your-frontend.vercel.app,https://your-domain.com

# Telegram Stars Billing (primary — Tier 1, no legal entity needed)
# Set in @BotFather → Payments → connect Telegram Stars
STARS_PRO_MONTHLY_AMOUNT=450
STARS_PRO_YEARLY_AMOUNT=3000

# Frontend URL (for success/cancel redirects)
FRONTEND_URL=https://your-frontend.vercel.app

