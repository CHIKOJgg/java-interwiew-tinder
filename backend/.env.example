DATABASE_URL=postgresql://user:password@localhost:5432/db
BOT_TOKEN=
OPENROUTER_API_KEY=
# Recommended models: google/gemini-2.0-flash-exp:free, mistralai/pixtral-12b:free
OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free
PORT=3000
ADMIN_TELEGRAM_IDS=
NODE_ENV=development
JWT_SECRET=
ALLOWED_ORIGINS=https://your-frontend.vercel.app,https://your-domain.com

# Telegram Stars Billing (primary — Tier 1, no legal entity needed)
# Set in @BotFather → Payments → connect Telegram Stars
STARS_PRO_MONTHLY_AMOUNT=450
STARS_PRO_YEARLY_AMOUNT=3000

# TON Crypto (Tier 1 — no entity needed)
# Your TON wallet address to receive payments
TON_WALLET_ADDRESS=UQ...your_ton_wallet
# Optional: get from toncenter.com
TON_CENTER_API_KEY=
TON_PRO_MONTHLY_AMOUNT=2.0
TON_PRO_YEARLY_AMOUNT=13.0

# Frontend URL (for success/cancel redirects)
FRONTEND_URL=https://your-frontend.vercel.app

# Redis (for rate-limiting and AI caching)
# Local: redis://localhost:6379
# Production: use Upstash or Fly.io Redis
REDIS_URL=

# Sentry (Observability)
SENTRY_DSN=

# Logtail / BetterStack (Log Shipping)
LOGTAIL_TOKEN=

# Stripe — disabled for BY sellers, kept for reference
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRO_MONTHLY_PRICE_ID=
# STRIPE_PRO_YEARLY_PRICE_ID=
