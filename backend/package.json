{
  "name": "java-interview-tinder-backend",
  "version": "1.0.0",
  "description": "Backend for Java Interview Tinder Telegram Mini App",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "start:worker": "node src/worker.js",
    "start:all": "node scripts/start-all.mjs",
    "dev": "node --watch src/server.js",
    "init-db": "node src/scripts/init-db.js",
    "seed-db": "node src/scripts/seed-db.js",
    "migrate": "node src/scripts/migrate.js",
    "setup-rb-db": "node src/scripts/migrate.js",
    "smoke:waitlist": "node src/scripts/smoke-waitlist.js",
    "migrate-stars": "node src/scripts/migrate-stars.js",
    "migrate-ton": "node src/scripts/migrate-ton.js",
    "migrate-ukassa": "node src/scripts/migrate-ukassa.js",
    "worker": "node src/worker.js",
    "generate-seo": "node src/scripts/generate-seo.js",
    "test": "vitest run tests/",
    "test:coverage": "vitest run tests/ --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "vercel-build": "echo 'Build completed'",
    "setup-db": "npm run init-db && npm run migrate && npm run migrate-stars && npm run migrate-ton && npm run migrate-ukassa && npm run seed-db && node src/scripts/seed-java-2.js && node src/scripts/seed-python.js"
  },
  "keywords": [
    "telegram",
    "mini-app",
    "java",
    "interview"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@logtail/pino": "^0.5.8",
    "@sentry/node": "^10.52.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.1",
    "helmet": "^8.2.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^4.2.1",
    "nodemailer": "^9.0.3",
    "pg": "^8.11.3",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "stripe": "^22.1.1",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^9.39.4",
    "globals": "^17.6.0",
    "supertest": "^7.2.2",
    "vitest": "^4.1.5"
  }
}
