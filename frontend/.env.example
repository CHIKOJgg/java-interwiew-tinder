# Public API URL the SPA talks to. Build-time variable: must be set BEFORE `npm run build`.
# Examples:
#   local dev:     http://localhost:3000/api
#   Render:        https://<your-service>.onrender.com/api
#   Fly.io:        https://<your-app>.fly.dev/api
VITE_API_URL=https://your-backend.example.com/api
VITE_SENTRY_DSN=
# Google One Tap (web/PWA login). Leave empty to disable Google sign-in.
VITE_GOOGLE_CLIENT_ID=
# Google Analytics 4 measurement ID (G-XXXXXXXXXX). Leave empty to disable.
VITE_GA_MEASUREMENT_ID=
# Telegram bot username (used for referral/share links). No leading @.
VITE_TELEGRAM_BOT_USERNAME=JavaInterviewTinderBot
